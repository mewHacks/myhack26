# Copy to .env.local for local dev

# Use your LoRA model (after ./scripts/setup-lora-model.sh)
LLM_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=covalent-gemma

# Optional: Gemini instead of Ollama (Cloud Run without self-hosted GPU)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key
# GEMINI_MODEL=gemini-2.0-flash

LLM_TIMEOUT_MS=120000
LLM_ENABLED=true
